
ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('ViewDefinition [CoordinationView]'),'2;1');
FILE_NAME('multi_pipe_clash.ifc','2026-04-05T12:00:00',('Generator'),('Generator'),'IFC Generator','ChatGPT','');
FILE_SCHEMA(('IFC4'));
ENDSEC;
DATA;

#1 = IFCPERSON($,$,'User',$,$,$,$,$);
#2 = IFCORGANIZATION($,'AI Generator',$,$,$);
#3 = IFCPERSONANDORGANIZATION(#1,#2,$);
#4 = IFCAPPLICATION(#2,'1.0','PipeClashGen','APP1');
